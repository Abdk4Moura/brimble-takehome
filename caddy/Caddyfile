{
	# Bind admin to all interfaces inside the caddy container so the api
	# service can push config via http://caddy:2019/load. The container is
	# only on the brimble-net network and not exposed on the host.
	admin 0.0.0.0:2019
	auto_https off
}

# Boot config. The api replaces this whole config via the admin API at
# startup (and on every deployment change). Until then we return a
# placeholder so curl-checks and browser hits get something instead of
# a connection refused.
:80 {
	respond "brimble-takehome: caddy up, api still booting" 503
}
